{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrimeSkill Pro",
  "version": "0.1.0",
  "identifier": "com.primeskill.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:4174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PrimeSkill Pro",
        "width": 1320,
        "height": 880,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
